generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserTier {
  free
  premium
}

enum AdminRole {
  super_admin
  content_manager
  verification_manager
  support_admin
  finance_admin
}

enum ArtistStatus {
  pending
  active
  suspended
}

enum UploadStatus {
  pending
  published
  rejected
  draft
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  username      String?  @unique
  avatarUrl     String?  @map("avatar_url")
  bio           String?
  tier          UserTier @default(free)
  emailVerified Boolean  @default(true) @map("email_verified")
  verifyToken   String?  @map("verify_token")
  verifyExpires DateTime? @map("verify_expires")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole @default(support_admin)
  avatarUrl    String?   @map("avatar_url")
  createdById  String?   @map("created_by_id")
  createdBy    Admin?    @relation("AdminHierarchy", fields: [createdById], references: [id])
  subAdmins    Admin[]   @relation("AdminHierarchy")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admins")
}

model Artist {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String       @map("password_hash")
  stageName     String       @map("stage_name")
  legalName     String       @map("legal_name")
  genre         String
  country       String
  bio           String?
  imageUrl      String?      @map("image_url")
  status        ArtistStatus @default(pending)
  emailVerified Boolean      @default(false) @map("email_verified")
  verifyToken   String?      @map("verify_token")
  verifyExpires DateTime?    @map("verify_expires")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  uploads       ArtistUpload[]

  @@map("artists")
}

model ArtistUpload {
  id                 String       @id @default(uuid())
  artistId           String       @map("artist_id")
  artist             Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title              String
  artistName         String       @map("artist_name")
  albumTitle         String       @map("album_title")
  releaseType        String?      @map("release_type")
  albumGroupId       String?      @map("album_group_id")
  trackNumber        Int?         @map("track_number")
  genre              String
  about              String?
  producers          String
  songwriters        String?
  featuredArtists    String?      @map("featured_artists")
  lyrics             String?
  coverUrl           String       @map("cover_url")
  audioFileName      String       @map("audio_file_name")
  duration           Int          @default(180)
  releaseDate        DateTime     @map("release_date")
  explicit           Boolean      @default(false)
  copyrightConfirmed Boolean      @default(false) @map("copyright_confirmed")
  status             UploadStatus @default(pending)
  submittedAt        DateTime     @default(now()) @map("submitted_at")

  @@map("artist_uploads")
}
