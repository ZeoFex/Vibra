# Required for Prisma CLI (db push, migrate) and the app. Copy to .env.local:
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

JWT_SECRET="your-jwt-secret"
ADMIN_JWT_SECRET="your-admin-jwt-secret"
ADMIN_OPEN_REGISTRATION="true"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google SMTP for artist email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
# App password from https://myaccount.google.com/apppasswords (no spaces)
SMTP_PASS=your16charapppassword
SMTP_FROM="Vibra <your-email@gmail.com>"

CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Paystack (placeholder — not wired yet)
